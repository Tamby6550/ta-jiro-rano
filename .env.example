# ─────────────────────────────────────────────────────────────
#  TA·JIRO·RANO — variables d'environnement
#  Copier en `.env` (local) et déclarer dans Vercel (prod).
#  ⚠️  SEULE l'anon key est exposée côté client. La service_role
#      ne doit JAMAIS apparaître ici ni dans le repo.
# ─────────────────────────────────────────────────────────────

# URL du projet Supabase (ex: https://xxxx.supabase.co)
SUPABASE_URL=

# Clé publique anon (Project Settings → API → anon public)
SUPABASE_ANON_KEY=

# (Local uniquement) URL de connexion Postgres pour lancer les tests SQL
# Fournie par `supabase start`. Ne pas committer.
SUPABASE_DB_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

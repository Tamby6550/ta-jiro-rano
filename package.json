{
  "name": "ta-jiro-rano",
  "version": "1.0.0",
  "description": "Gestion et répartition des factures JIRAMA (sous-compteurs) — Angular 19 + Supabase",
  "license": "MIT",
  "scripts": {
    "start": "ng serve",
    "config": "node scripts/set-env.js",
    "prebuild": "node scripts/set-env.js",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "lint": "ng lint",
    "db:start": "supabase start",
    "db:reset": "supabase db reset",
    "db:push": "supabase db push",
    "db:test": "supabase db reset && psql \"$SUPABASE_DB_URL\" -f supabase/tests/test_calculs.sql",
    "types:gen": "supabase gen types typescript --local > src/app/core/database.types.ts"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^19.0.0",
    "@angular/common": "^19.0.0",
    "@angular/compiler": "^19.0.0",
    "@angular/core": "^19.0.0",
    "@angular/forms": "^19.0.0",
    "@angular/platform-browser": "^19.0.0",
    "@angular/platform-browser-dynamic": "^19.0.0",
    "@angular/router": "^19.0.0",
    "@supabase/supabase-js": "^2.45.0",
    "browser-image-compression": "^2.0.2",
    "chart.js": "^4.4.0",
    "jspdf": "^2.5.2",
    "jspdf-autotable": "^3.8.4",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^19.0.0",
    "@angular/cli": "^19.0.0",
    "@angular/compiler-cli": "^19.0.0",
    "typescript": "~5.6.0"
  }
}
